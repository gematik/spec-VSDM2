          "system": "url",
          "value": "https://fachportal.gematik.de/anwendungen/versichertenstammdaten-management"
        }
      ]
    }
  ],
  "description": "Angaben zum GKV-Versicherungsverhältnis im Versichertenstammdatenmanagement (VSDM) 2.0",
  "jurisdiction": [
    {
      "coding": [
        {
          "code": "DE",
          "system": "urn:iso:std:iso:3166",
          "display": "Germany"
        }
      ]
    }
  ],
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "Coverage",
  "baseDefinition": "https://gematik.de/fhir/vsdm2/StructureDefinition/VSDMCoverageGKVBase",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Coverage",
        "path": "Coverage",
        "definition": "Angaben zum GKV-Versicherungsverhältnis im Versichertenstammdatenmanagement (VSDM) 2.0.\nDieses Profil bildet die im VSDM 2.0-Bundle zu verwendenden Inhalte ab.",
        "constraint": [
          {
            "key": "VSDMCoverageGKV-gender-1",
            "severity": "error",
            "human": "Für GKV-Versicherte ist die Angabe des Geschlechts erforderlich.",
            "expression": "beneficiary.resolve().gender.exists()",
            "source": "https://gematik.de/fhir/vsdm2/StructureDefinition/VSDMCoverageGKV"
          },
          {
            "key": "VSDMCoverageGKV-gender-2",
            "severity": "error",
            "human": "Für GKV-Versicherte ist die Geschlechtsangabe 'unknown' nicht erlaubt.",
            "expression": "beneficiary.resolve().gender != 'unknown'",
            "source": "https://gematik.de/fhir/vsdm2/StructureDefinition/VSDMCoverageGKV"
          },
          {
            "key": "VSDMCoverageGKV-address-1",
            "severity": "error",
            "human": "Für GKV-Versicherte ist die Angabe des Länderkennzeichens nach DEÜV Anlage 8 in Adressen des Patienten erforderlich.",
            "expression": "beneficiary.resolve().address.all(country.extension('https://gematik.de/fhir/vsdm2/StructureDefinition/VSDMLaenderkennzeichenAnlage8').exists())",
            "source": "https://gematik.de/fhir/vsdm2/StructureDefinition/VSDMCoverageGKV"
          },
          {
            "key": "VSDMCoverageGKV-address-2",
            "severity": "error",
            "human": "Für GKV-Versicherte ist die Angabe des Länderkennzeichens nach DEÜV Anlage 8 in Adressen des Kostenträgers erforderlich.",
            "expression": "payor.all(resolve().address.all(country.extension('https://gematik.de/fhir/vsdm2/StructureDefinition/VSDMLaenderkennzeichenAnlage8').exists()))",
            "source": "https://gematik.de/fhir/vsdm2/StructureDefinition/VSDMCoverageGKV"
          }
        ]
      },
      {
        "id": "Coverage.status",
        "path": "Coverage.status",
        "comment": "Im VSDM 2.0 werden nur Informationen über aktive Versicherungsverhältnisse ausgetauscht.",
        "fixedCode": "active"
      },
      {
        "id": "Coverage.beneficiary",
        "path": "Coverage.beneficiary",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://gematik.de/fhir/vsdm2/StructureDefinition/VSDMPatient"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Coverage.payor",
        "path": "Coverage.payor",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://gematik.de/fhir/vsdm2/StructureDefinition/VSDMPayorOrganization"
            ]
          }
        ],
        "constraint": [
          {
            "key": "VSDMCoverageGKV-payor-1",
            "severity": "error",
            "human": "Die IK-Nummer in der Kostenträger-Referenz muss mit der IK-Nummer in der referenzierten Organisation übereinstimmen.",
            "expression": "resolve().identifier.exists(value = $this.value)",
            "source": "https://gematik.de/fhir/vsdm2/StructureDefinition/VSDMCoverageGKV"
          },
          {
            "key": "VSDMCoverageGKV-payor-2",
            "severity": "error",
            "human": "Der Anzeigetext der Kostenträger-Referenz muss mit dem Anzeigenamen der referenzierten Organisation übereinstimmen.",
            "expression": "resolve().name = $this.display",
            "source": "https://gematik.de/fhir/vsdm2/StructureDefinition/VSDMCoverageGKV"
          }
        ]
      },
      {
        "id": "Coverage.payor.reference",
        "path": "Coverage.payor.reference",
        "min": 1
      },
      {
        "id": "Coverage.payor.identifier",
        "path": "Coverage.payor.identifier",
        "min": 1
      },
      {
        "id": "Coverage.payor.display",
        "path": "Coverage.payor.display",
        "min": 1
      }
    ]
  }
}
